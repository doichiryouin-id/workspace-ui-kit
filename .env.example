# YouTube 分析（Pane 3 / Pane 4）
# 手順: docs/YOUTUBE-ANALYTICS-SETUP.md
# 対話式セットアップ: npm run setup:youtube-oauth

# 視聴回数・高評価・コメント（Pane 3・任意だが推奨）
YOUTUBE_API_KEY=

# OAuth（Pane 3 分析 + Pane 4 マイルストーン IMP/CTR に必須）
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# 通常は空で OK（認可したチャンネルが使われる）
YOUTUBE_CHANNEL_ID=

# reach レポートジョブ ID（通常は空。自動作成される）
YOUTUBE_REACH_REPORT_JOB_ID=

# Supabase クラウド同期（任意）
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# パスワード保護（任意・未設定ならログインなし）
# WORKSPACE_ACCESS_PASSWORD=
# AUTH_SECRET=
